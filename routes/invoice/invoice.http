### ─── Invoice Routes ─────────────────────────────────────────────────────────

@baseUrl = http://localhost:3000
@token = YOUR_JWT_TOKEN_HERE
@invoiceId = ABC1234

### ── GET /invoice/required-data ─────────────────────────────────────────────

GET {{baseUrl}}/invoice/required-data
Authorization: Bearer {{token}}

### ── POST /invoice/add ───────────────────────────────────────────────────────

POST {{baseUrl}}/invoice/add
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "patient": {
    "name": "John Doe",
    "gender": "male",
    "age": 35,
    "contactNumber": "01712345678"
  },
  "referrer": {
    "id": "507f1f77bcf86cd799439011",
    "name": "Dr. Smith",
    "type": "doctor"
  },
  "tests": [
    {
      "testId": "507f1f77bcf86cd799439012",
      "name": "Complete Blood Count",
      "price": 500,
      "schemaId": "507f1f77bcf86cd799439013"
    },
    {
      "testId": "507f1f77bcf86cd799439014",
      "name": "Blood Sugar",
      "price": 300,
      "schemaId": null
    }
  ],
  "amount": {
    "initial": 800,
    "referrerDiscount": 50,
    "referrerCommission": 80,
    "labAdjustment": 0,
    "final": 750,
    "net": 670,
    "paid": 500
  }
}

### ── POST /invoice/add (no referrer) ────────────────────────────────────────

POST {{baseUrl}}/invoice/add
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "patient": {
    "name": "Jane Doe",
    "gender": "female",
    "age": 28,
    "contactNumber": "01798765432"
  },
  "tests": [
    {
      "testId": "507f1f77bcf86cd799439012",
      "name": "Complete Blood Count",
      "price": 500,
      "schemaId": null
    }
  ],
  "amount": {
    "initial": 500,
    "referrerDiscount": 0,
    "referrerCommission": 0,
    "labAdjustment": 0,
    "final": 500,
    "net": 500,
    "paid": 500
  }
}

### ── POST /invoice/add (paid > final — should fail 400) ─────────────────────

POST {{baseUrl}}/invoice/add
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "patient": {
    "name": "Test Patient",
    "gender": "male",
    "age": 40,
    "contactNumber": "01700000000"
  },
  "tests": [
    {
      "testId": "507f1f77bcf86cd799439012",
      "name": "Complete Blood Count",
      "price": 500,
      "schemaId": null
    }
  ],
  "amount": {
    "initial": 500,
    "referrerDiscount": 0,
    "referrerCommission": 0,
    "labAdjustment": 0,
    "final": 500,
    "net": 500,
    "paid": 999
  }
}

### ── PATCH /invoice/:invoiceId/collect-due ──────────────────────────────────

PATCH {{baseUrl}}/invoice/{{invoiceId}}/collect-due
Authorization: Bearer {{token}}

### ── GET /invoice/all ────────────────────────────────────────────────────────

GET {{baseUrl}}/invoice/all
Authorization: Bearer {{token}}

### ── GET /invoice/all (with pagination) ─────────────────────────────────────

GET {{baseUrl}}/invoice/all?limit=20&cursor=1748000000000
Authorization: Bearer {{token}}

### ── GET /invoice/all (with date range) ─────────────────────────────────────

GET {{baseUrl}}/invoice/all?startDate=1745000000000&endDate=1748000000000
Authorization: Bearer {{token}}

### ── GET /invoice/all (date range + pagination) ─────────────────────────────

GET {{baseUrl}}/invoice/all?startDate=1745000000000&endDate=1748000000000&limit=20&cursor=1747000000000
Authorization: Bearer {{token}}

### ── GET /invoice/deleted ────────────────────────────────────────────────────

GET {{baseUrl}}/invoice/deleted
Authorization: Bearer {{token}}

### ── GET /invoice/deleted (with date range) ─────────────────────────────────

GET {{baseUrl}}/invoice/deleted?startDate=1745000000000&endDate=1748000000000
Authorization: Bearer {{token}}

### ── GET /invoice/:invoiceId ─────────────────────────────────────────────────

GET {{baseUrl}}/invoice/{{invoiceId}}
Authorization: Bearer {{token}}

### ── GET /invoice/:invoiceId/report-summary ─────────────────────────────────

GET {{baseUrl}}/invoice/{{invoiceId}}/report-summary
Authorization: Bearer {{token}}

### ── PATCH /invoice/:invoiceId/patient-info ─────────────────────────────────

PATCH {{baseUrl}}/invoice/{{invoiceId}}/patient-info
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "patient": {
    "name": "John Doe Updated",
    "gender": "male",
    "age": 36,
    "contactNumber": "01712345999"
  }
}

### ── PATCH /invoice/:invoiceId/mark-delivered ───────────────────────────────

PATCH {{baseUrl}}/invoice/{{invoiceId}}/mark-delivered
Authorization: Bearer {{token}}

### ── PATCH /invoice/:invoiceId/delete ───────────────────────────────────────

PATCH {{baseUrl}}/invoice/{{invoiceId}}/delete
Authorization: Bearer {{token}}

### ── Edge Cases ──────────────────────────────────────────────────────────────

### collect-due on already paid invoice (should fail 400)
PATCH {{baseUrl}}/invoice/{{invoiceId}}/collect-due
Authorization: Bearer {{token}}

### mark-delivered on already delivered invoice (should fail 400)
PATCH {{baseUrl}}/invoice/{{invoiceId}}/mark-delivered
Authorization: Bearer {{token}}

### delete already deleted invoice (should fail 400)
PATCH {{baseUrl}}/invoice/{{invoiceId}}/delete
Authorization: Bearer {{token}}

### invalid invoiceId format (should fail 422)
GET {{baseUrl}}/invoice/INVALID123
Authorization: Bearer {{token}}

### missing required fields in body (should fail 422)
POST {{baseUrl}}/invoice/add
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "patient": {
    "name": "Missing Fields"
  }
}